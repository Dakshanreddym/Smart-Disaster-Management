spring.application.name=Project-Disaster-Management
spring.datasource.url=jdbc:mysql://localhost:3306/disaster_management_project
spring.datasource.username=_mysql_username
spring.datasource.password=_mysql_password
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

logging.level.org.springframework.security=DEBUG
server.servlet.session.timeout=10m

spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.mode=HTML
spring.thymeleaf.encoding=UTF-8

spring.web.resources.static-locations=classpath:/static/
